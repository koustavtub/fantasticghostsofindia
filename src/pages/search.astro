---
import BookLayout from '../layouts/BookLayout.astro';
import GhostCard from '../components/GhostCard.astro';
import { highlightMatch } from '../lib/markdown';
import { searchGhosts } from '../lib/ghosts';

const query = Astro.url.searchParams.get('q') ?? '';
let results = [];

try {
  if (query.trim()) {
    results = await searchGhosts(query.trim(), 50);
  }
} catch {
  results = [];
}
---

<BookLayout title={query ? `Search: ${query} — Fantastic Ghosts of India` : 'Search — Fantastic Ghosts of India'}>
  <div class="page-enter">
    <header class="text-center mb-10">
      <h1 class="font-display text-3xl md:text-4xl text-gold tracking-wide mb-3">Search the Codex</h1>
      <p class="text-parchment/60 text-lg">Seek by name, region, or lore.</p>
    </header>

    <form action="/search" method="get" class="max-w-xl mx-auto mb-12">
      <input
        type="search"
        name="q"
        value={query}
        placeholder="Enter your query…"
        class="w-full bg-ink/60 border border-gold/30 text-parchment placeholder:text-parchment/40 px-4 py-3 font-body text-xl focus:outline-none focus:border-gold"
        autofocus
      />
    </form>

    {query.trim() === '' ? (
      <p class="text-center text-parchment/40 italic">Type to search the encyclopaedia.</p>
    ) : results.length === 0 ? (
      <div class="text-center py-16 paper-panel ornate-border max-w-md mx-auto">
        <p class="font-display text-xl text-ink/60 mb-2">No spirits found</p>
        <p class="text-ink/40">Try a different name, region, or keyword.</p>
      </div>
    ) : (
      <div>
        <p class="text-parchment/50 text-sm mb-6 text-center">
          {results.length} result{results.length === 1 ? '' : 's'} for &ldquo;{query}&rdquo;
        </p>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {results.map((ghost) => (
            <div>
              <GhostCard ghost={ghost} />
              <p class="text-parchment/40 text-sm mt-2 px-1 line-clamp-2" set:html={highlightMatch(ghost.summary, query)} />
            </div>
          ))}
        </div>
      </div>
    )}
  </div>
</BookLayout>
