---
import BookLayout from '../layouts/BookLayout.astro';
---

<BookLayout title="Not Found — Fantastic Ghosts of India">
  <div class="page-enter min-h-[50vh] flex items-center justify-center">
    <div class="paper-panel ornate-border p-12 text-center max-w-md">
      <p class="font-display text-6xl text-gold/30 mb-4">404</p>
      <h1 class="font-display text-2xl text-ink mb-4">Spirit Not Found</h1>
      <p class="text-ink/60 mb-8">
        This page has vanished like a bhoot at dawn. The entry you seek is not in the codex.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/codex" class="btn-primary">Browse Codex</a>
        <a href="/" class="btn-secondary">Return Home</a>
      </div>
    </div>
  </div>
</BookLayout>
